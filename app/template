---


### `app/dashboard/page.tsx` — Protected Page (Server Component)


```tsx
import { createClient } from "@/lib/supabase/server";
import { redirect } from "next/navigation";
import { signOut } from "@/app/auth/actions";


export default async function DashboardPage() {
  const supabase = await createClient();


  // Server-side auth check (middleware already guards this, this is a safety net)
  const {
    data: { user },
  } = await supabase.auth.getUser();


  if (!user) redirect("/login");


  // Example: fetch data from Supabase (BAAS - no custom backend needed)
  const { data: items } = await supabase
    .from("items") // replace with your table name
    .select("*")
    .eq("user_id", user.id);


  return (
    <main className="min-h-screen bg-gray-50">
      <nav className="flex items-center justify-between px-8 py-4 bg-white border-b">
        <span className="font-bold">Dashboard</span>
        <div className="flex items-center gap-4">
          <span className="text-sm text-gray-500">{user.email}</span>
          <form action={signOut}>
            <button
              type="submit"
              className="text-sm text-red-500 hover:text-red-700"
            >
              Sign out
            </button>
          </form>
        </div>
      </nav>


      <div className="max-w-4xl mx-auto py-12 px-4">
        <h1 className="text-3xl font-bold mb-8">Hello 👋</h1>


        <pre className="bg-white border rounded-xl p-4 text-sm overflow-auto">
          {JSON.stringify(items ?? [], null, 2)}
        </pre>
      </div>
    </main>
  );
}
```


---


## 7. Auth Callback Route (Email Confirmation)


### `app/auth/callback/route.ts`


Required for **email verification** links to work.


```ts
import { NextResponse } from "next/server";
import { createClient } from "@/lib/supabase/server";


export async function GET(request: Request) {
  const { searchParams, origin } = new URL(request.url);
  const code = searchParams.get("code");
  const next = searchParams.get("next") ?? "/dashboard";


  if (code) {
    const supabase = await createClient();
    const { error } = await supabase.auth.exchangeCodeForSession(code);
    if (!error) {
      return NextResponse.redirect(`${origin}${next}`);
    }
  }


  return NextResponse.redirect(`${origin}/login?error=Could not verify email`);
}
```


Also update your **Supabase Dashboard → Authentication → URL Configuration**:
- Site URL: `http://localhost:3000` (dev) / your prod URL
- Redirect URLs: `http://localhost:3000/auth/callback`


---


## 8. Client Component Example (with real-time / interactive)


### `components/UserProfile.tsx`
> When you need client-side Supabase access (real-time subscriptions, etc.)


```tsx
"use client";


import { useEffect, useState } from "react";
import { createClient } from "@/lib/supabase/client";


export default function UserProfile() {
  const [user, setUser] = useState<any>(null);
  const supabase = createClient();


  useEffect(() => {
    supabase.auth.getUser().then(({ data }) => setUser(data.user));


    const { data: listener } = supabase.auth.onAuthStateChange(
      (_event, session) => {
        setUser(session?.user ?? null);
      }
    );


    return () => listener.subscription.unsubscribe();
  }, []);


  if (!user) return null;


  return (
    <div className="text-sm text-gray-600">
      Signed in as <strong>{user.email}</strong>
    </div>
  );
}
```


---


## 9. Supabase RLS (Row Level Security)


Since you're using **BAAS** (no custom backend), enable RLS on all tables:


```sql
-- In Supabase SQL editor


-- Enable RLS
ALTER TABLE items ENABLE ROW LEVEL SECURITY;


-- Users can only see their own rows
CREATE POLICY "Users can view own items"
  ON items FOR SELECT
  USING (auth.uid() = user_id);


-- Users can only insert their own rows
CREATE POLICY "Users can insert own items"
  ON items FOR INSERT
  WITH CHECK (auth.uid() = user_id);


-- Users can only update their own rows
CREATE POLICY "Users can update own items"
  ON items FOR UPDATE
  USING (auth.uid() = user_id);
```


---


## 10. Final File Structure


```
your-nextjs-app/
├── app/
│   ├── page.tsx                    ← Public landing page
│   ├── login/
│   │   └── page.tsx                ← Login page
│   ├── signup/
│   │   └── page.tsx                ← Sign up page
│   ├── dashboard/
│   │   └── page.tsx                ← Protected dashboard (SSR)
│   └── auth/
│       ├── actions.ts              ← Server Actions (signIn, signUp, signOut)
│       └── callback/
│           └── route.ts            ← Email confirmation callback
├── components/
│   └── UserProfile.tsx             ← Client Component example
├── lib/
│   └── supabase/
│       ├── client.ts               ← Browser client (use client components)
│       ├── server.ts               ← Server client (use server components)
│       └── middleware.ts           ← Middleware session refresher
├── middleware.ts                   ← Root middleware (session + route protection)
└── .env.local                      ← Supabase URL + Anon Key
```


---


## How It All Works Together


| Layer | File | Purpose |
|---|---|---|
| **Public** | `app/page.tsx` | Landing page — no auth needed |
| **Auth UI** | `app/login/`, `app/signup/` | Email/password forms |
| **Server Actions** | `app/auth/actions.ts` | Secure sign in/up/out via server |
| **Middleware** | `middleware.ts` | Refresh sessions + guard protected routes |
| **SSR Data** | `app/dashboard/page.tsx` | Fetch from Supabase on server |
| **CSR/Realtime** | `components/UserProfile.tsx` | Client-side Supabase access |
| **Callback** | `app/auth/callback/route.ts` | Handle email verification links |
| **Security** | Supabase RLS policies | Row-level security (no custom backend needed) |


---


## Key Concepts


- **No custom backend** — Supabase is your BAAS. Server Actions call Supabase directly.
- **SSR by default** — `dashboard/page.tsx` fetches data server-side; no API routes needed for reads.
- **Protected routes** — Middleware redirects unauthenticated users. Server pages double-check.
- **Shared auth with Expo** — Both apps use the same Supabase project. Users created in Expo appear in Next.js automatically.
- **`@supabase/ssr`** — The correct package for Next.js App Router. Never use `createClient` from `@supabase/supabase-js` directly on the server.



